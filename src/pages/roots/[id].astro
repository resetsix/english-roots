---
import ExampleBreakdown from '@/components/ExampleBreakdown.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { wordRoots } from '@/data/wordRoots'
import { displayOrigin } from '@/lib/origin'

export function getStaticPaths() {
  return wordRoots.map((root) => ({
    params: { id: String(root.id) },
    props: { root },
  }))
}

const { root } = Astro.props
const rootNotes = [
  root.memoryHint ? ['记忆抓手', root.memoryHint] : null,
  root.commonPitfall ? ['易错提醒', root.commonPitfall] : null,
  root.variants?.length ? ['常见变体', root.variants.join(' / ')] : null,
].filter(Boolean) as [string, string][]
---

<BaseLayout title={`${root.root} - 词根详情`} activePath="/roots">
  <article class="wr-container root-detail" data-root-id={root.id}>
    <a class="back-link" href="/roots">← 返回词根列表</a>

    <header class="detail-hero wr-panel">
      <div class="detail-hero__main">
        <div class="wr-kicker">Root #{root.id}</div>
        <h1 class="detail-title wr-wordmark">{root.root}</h1>
        <div class="detail-meta">
          <span class="wr-chip">{displayOrigin(root.origin)}</span>
          <span>{root.meaning}</span>
        </div>
        <p class="detail-description">{root.description}</p>
      </div>

      <aside class="detail-notes" aria-label="词条边注">
        <div class="detail-notes__title">词条边注</div>
        <div class="detail-note">
          <span>学习目标</span>
          <strong>会用 {root.root} 解释例词，而不是只背中文释义。</strong>
        </div>
        {
          rootNotes.map(([label, text]) => (
            <div class="detail-note">
              <span>{label}</span>
              <strong>{text}</strong>
            </div>
          ))
        }
      </aside>
    </header>

    <section class="detail-section example-section">
      <div class="section-head">
        <div>
          <h2 class="wr-section-title">例词拆页</h2>
          <p>
            每个例词按「词素公式 → 字面组合义 →
            自然义」阅读，先理解结构，再记住真实用法。
          </p>
        </div>
      </div>
      <div class="example-grid">
        {root.examples.map((example) => <ExampleBreakdown example={example} />)}
      </div>
    </section>

    <section
      class="detail-section quiz-panel"
      data-quiz
      data-correct={root.quiz.correctAnswer}
    >
      <div class="section-head">
        <div>
          <h2 class="wr-section-title">合上书以后</h2>
          <p>先选最贴近词根核心义的答案，答完再回到例词核对。</p>
        </div>
      </div>
      <div class="quiz-layout">
        <p class="quiz-question">{root.quiz.question}</p>
        <div class="quiz-options">
          {
            root.quiz.options.map((option, index) => (
              <button class="quiz-option" type="button" data-index={index}>
                {option}
              </button>
            ))
          }
        </div>
        <p class="quiz-feedback" data-feedback hidden></p>
      </div>
    </section>

    <div class="detail-actions">
      <a class="wr-button" href="/roots">返回列表</a>
      <a
        class="wr-button wr-button--primary"
        href={`/learn?index=${root.id - 1}`}>从这里学习</a
      >
    </div>
  </article>
</BaseLayout>

<script>
  import { markRootAsMastered } from '@/lib/storage'

  const quiz = document.querySelector<HTMLElement>('[data-quiz]')
  const correctIndex = Number(quiz?.dataset.correct)
  const buttons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.quiz-option'),
  )
  const feedback = document.querySelector<HTMLElement>('[data-feedback]')
  const rootId = Number(
    document.querySelector<HTMLElement>('[data-root-id]')?.dataset.rootId,
  )

  function normalizeQuizAnswer(answer: string) {
    return answer
      .replace(/\s+/g, '')
      .replace(/[，,、/／;；]/g, '/')
      .trim()
  }

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      const selectedIndex = Number(button.dataset.index)
      const correctAnswer = buttons[correctIndex]?.textContent?.trim() ?? ''
      const selectedAnswer = button.textContent?.trim() ?? ''
      const normalizedCorrectAnswer = normalizeQuizAnswer(correctAnswer)
      const isCorrect =
        selectedIndex === correctIndex ||
        normalizeQuizAnswer(selectedAnswer) === normalizedCorrectAnswer

      buttons.forEach((item) => {
        const itemIndex = Number(item.dataset.index)
        const isEquivalentCorrectAnswer =
          normalizeQuizAnswer(item.textContent?.trim() ?? '') ===
          normalizedCorrectAnswer
        item.disabled = true
        item.classList.toggle('is-correct', isEquivalentCorrectAnswer)
        item.classList.toggle(
          'is-wrong',
          itemIndex === selectedIndex &&
            !isCorrect &&
            !isEquivalentCorrectAnswer,
        )
      })

      if (feedback) {
        feedback.hidden = false
        feedback.classList.toggle('is-correct', isCorrect)
        feedback.classList.toggle('is-wrong', !isCorrect)
        feedback.textContent = isCorrect
          ? '答对了，已计入掌握进度。'
          : `答错了。正确答案是：${correctAnswer}`
      }

      if (isCorrect && rootId) {
        markRootAsMastered(rootId)
      }
    })
  })
</script>

<style>
  .root-detail {
    padding-top: 8px;
  }

  .back-link {
    color: var(--wr-ink-muted);
    font-weight: 700;
    text-decoration: none;
  }

  .detail-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    gap: clamp(18px, 4vw, 34px);
    margin-top: 30px;
    padding: clamp(22px, 4vw, 34px);
  }

  .detail-hero::before {
    display: none;
  }

  .detail-title {
    font-size: clamp(3.2rem, 10vw, 6rem);
    line-height: 1;
    margin: 12px 0 18px;
  }

  .detail-meta {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 14px;
    color: var(--wr-ink-muted);
    font-size: 1.1rem;
  }

  .detail-section {
    margin-top: 42px;
  }

  .example-section {
    margin-top: 30px;
  }

  .example-section + .quiz-panel {
    margin-top: 36px;
  }

  .detail-description {
    color: var(--wr-ink-muted);
    font-size: 1.05rem;
    margin: 22px 0 0;
    max-width: 700px;
  }

  .detail-notes {
    display: grid;
    align-content: start;
    gap: 12px;
    border-left: 1px solid var(--wr-rule);
    padding-left: clamp(18px, 3vw, 28px);
  }

  .detail-notes__title {
    color: var(--wr-ink);
    font-size: 1.05rem;
    font-weight: 760;
  }

  .detail-note {
    display: grid;
    gap: 5px;
    border: 1px solid var(--wr-rule);
    border-radius: var(--wr-radius);
    background: color-mix(
      in srgb,
      var(--wr-paper-deep) 52%,
      var(--wr-paper-panel)
    );
    padding: 12px;
  }

  .detail-note span,
  .section-head p {
    color: var(--wr-ink-faint);
    font-size: 0.86rem;
  }

  .detail-note strong {
    color: var(--wr-ink-muted);
    font-weight: 650;
    line-height: 1.65;
  }

  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 16px;
  }

  .section-head p {
    margin: 0;
  }

  .example-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .quiz-question {
    color: var(--wr-ink);
    font-size: 1.08rem;
    font-weight: 760;
    margin: 0 0 16px;
  }

  .quiz-panel {
    border: 1px solid var(--wr-rule);
    border-radius: var(--wr-radius);
    background: var(--wr-paper-panel);
    padding: clamp(18px, 3vw, 24px);
  }

  .quiz-layout {
    max-width: 720px;
  }

  .quiz-options {
    display: grid;
    gap: 10px;
  }

  .quiz-option {
    min-height: 48px;
    border: 1px solid var(--wr-rule);
    border-radius: var(--wr-radius);
    background: var(--wr-paper);
    color: var(--wr-ink);
    cursor: pointer;
    padding: 12px 14px;
    text-align: left;
  }

  .quiz-option:hover:not(:disabled) {
    border-color: var(--wr-focus);
  }

  .quiz-option.is-correct {
    border-color: var(--wr-study);
    background: var(--wr-study-soft);
  }

  .quiz-option.is-wrong {
    border-color: var(--wr-danger);
    background: color-mix(in oklch, var(--wr-danger) 12%, transparent);
    color: var(--wr-danger);
  }

  .quiz-feedback {
    border-radius: var(--wr-radius);
    margin: 14px 0 0;
    padding: 12px;
  }

  .quiz-feedback.is-correct {
    background: var(--wr-study-soft);
  }

  .quiz-feedback.is-wrong {
    background: color-mix(in oklch, var(--wr-danger) 12%, transparent);
    color: var(--wr-danger);
  }

  .detail-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  @media (max-width: 760px) {
    .detail-hero {
      grid-template-columns: 1fr;
    }

    .detail-notes {
      border-left: 0;
      border-top: 1px solid var(--wr-rule);
      padding-left: 0;
      padding-top: 18px;
    }

    .example-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
