---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { totalWordRoots } from '@/data/wordRoots'
---

<BaseLayout title="闪卡模式 - 词词有据" activePath="/flashcard">
  <section class="flash-shell wr-narrow">
    <div
      class="flash-card"
      id="flash-card"
      role="button"
      tabindex="0"
      aria-label="点击翻转闪卡"
    >
      <div class="flash-card__inner">
        <div class="flash-face flash-face--front">
          <div class="wr-kicker">drawer card</div>
          <div class="flash-root wr-wordmark" id="front-root">-</div>
          <div class="flash-meaning" id="front-meaning">-</div>
          <div class="wr-chip" id="front-origin">拉丁语</div>
        </div>
        <div class="flash-face flash-face--back">
          <div class="flash-back-root wr-wordmark" id="back-root">-</div>
          <p class="flash-description" id="back-description">-</p>
          <div class="flash-examples" id="back-examples"></div>
          <div class="flash-inline-actions">
            <button
              class="wr-button wr-button--study"
              type="button"
              id="known-button">认识</button
            >
            <button class="wr-button" type="button" id="practice-button"
              >继续练习</button
            >
          </div>
        </div>
      </div>
    </div>

    <div class="flash-controls">
      <button class="wr-button" type="button" id="prev-card">上一个</button>
      <div class="flash-progress" id="flash-progress">1/{totalWordRoots}</div>
      <button class="wr-button wr-button--primary" type="button" id="next-card"
        >下一个</button
      >
    </div>
    <p class="flash-hint">点击纸卡翻面。键盘可用 ← / → 切换，空格翻转。</p>
  </section>
</BaseLayout>

<script>
  import { wordRoots } from '@/data/wordRoots'
  import { displayOrigin } from '@/lib/origin'
  import {
    getProgress,
    markRootAsMastered,
    updateStudyStreak,
  } from '@/lib/storage'

  const card = document.querySelector<HTMLElement>('#flash-card')
  const frontRoot = document.querySelector('#front-root')
  const frontMeaning = document.querySelector('#front-meaning')
  const frontOrigin = document.querySelector('#front-origin')
  const backRoot = document.querySelector('#back-root')
  const backDescription = document.querySelector('#back-description')
  const backExamples = document.querySelector('#back-examples')
  const progressText = document.querySelector('#flash-progress')
  const prevButton = document.querySelector('#prev-card')
  const nextButton = document.querySelector('#next-card')
  const knownButton = document.querySelector('#known-button')
  const practiceButton = document.querySelector('#practice-button')
  let index = 0

  updateStudyStreak()

  function escapeHtml(value: string) {
    return value.replace(/[&<>"']/g, (char) => {
      const entities: Record<string, string> = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      }
      return entities[char]
    })
  }

  function normalize(nextIndex: number) {
    if (nextIndex < 0) return wordRoots.length - 1
    if (nextIndex >= wordRoots.length) return 0
    return nextIndex
  }

  function renderCard(nextIndex: number) {
    index = normalize(nextIndex)
    const root = wordRoots[index]
    card?.classList.remove('is-flipped')

    if (frontRoot) frontRoot.textContent = root.root
    if (frontMeaning) frontMeaning.textContent = root.meaning
    if (frontOrigin) frontOrigin.textContent = displayOrigin(root.origin)
    if (backRoot) backRoot.textContent = root.root
    if (backDescription) backDescription.textContent = root.description
    if (backExamples) {
      backExamples.innerHTML = root.examples
        .slice(0, 3)
        .map(
          (example) => `
            <div class="flash-example">
              <strong>${escapeHtml(example.word)}</strong>
              <span>${escapeHtml(example.meaning)}</span>
            </div>
          `,
        )
        .join('')
    }

    const mastered = getProgress().masteredRoots.length
    if (progressText)
      progressText.textContent = `${index + 1}/${wordRoots.length} · 已掌握 ${mastered}`
  }

  function flip() {
    card?.classList.toggle('is-flipped')
  }

  card?.addEventListener('click', flip)
  card?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter' || event.key === ' ') {
      event.preventDefault()
      flip()
    }
  })
  prevButton?.addEventListener('click', () => renderCard(index - 1))
  nextButton?.addEventListener('click', () => renderCard(index + 1))
  practiceButton?.addEventListener('click', (event) => {
    event.stopPropagation()
    renderCard(index + 1)
  })
  knownButton?.addEventListener('click', (event) => {
    event.stopPropagation()
    markRootAsMastered(wordRoots[index].id)
    renderCard(index + 1)
  })

  document.addEventListener('keydown', (event) => {
    if (event.key === 'ArrowLeft') {
      event.preventDefault()
      renderCard(index - 1)
    }
    if (event.key === 'ArrowRight') {
      event.preventDefault()
      renderCard(index + 1)
    }
    if (event.key === ' ') {
      event.preventDefault()
      flip()
    }
  })

  let touchStartX = 0
  card?.addEventListener('touchstart', (event) => {
    touchStartX = event.changedTouches[0].screenX
  })
  card?.addEventListener('touchend', (event) => {
    const diff = touchStartX - event.changedTouches[0].screenX
    if (Math.abs(diff) < 50) return
    renderCard(diff > 0 ? index + 1 : index - 1)
  })

  renderCard(index)
</script>

<style>
  .flash-shell {
    display: grid;
    gap: 22px;
  }

  .flash-card {
    height: min(620px, 68vh);
    min-height: 440px;
    perspective: 1200px;
  }

  .flash-card__inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 360ms ease;
    transform-style: preserve-3d;
  }

  .flash-card.is-flipped .flash-card__inner {
    transform: rotateY(180deg);
  }

  .flash-face {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    backface-visibility: hidden;
    border: 1px solid var(--wr-rule);
    border-radius: var(--wr-radius);
    background:
      linear-gradient(transparent 31px, var(--wr-paper-line) 32px) 0 0 / 100%
        32px,
      var(--wr-paper-panel);
    padding: clamp(22px, 5vw, 42px);
    text-align: center;
    box-shadow: var(--wr-shadow);
  }

  .flash-face--front {
    background:
      linear-gradient(
          90deg,
          color-mix(in srgb, var(--wr-red-pencil) 18%, transparent) 0 1px,
          transparent 1px
        )
        28px 0 / 1px 100% no-repeat,
      linear-gradient(transparent 31px, var(--wr-paper-line) 32px) 0 0 / 100%
        32px,
      var(--wr-paper-panel);
  }

  .flash-face--back {
    transform: rotateY(180deg);
  }

  .flash-root {
    font-size: clamp(3.4rem, 13vw, 7.6rem);
    line-height: 1;
    margin: 22px 0 16px;
  }

  .flash-meaning {
    color: var(--wr-ink-muted);
    font-size: clamp(1.3rem, 4vw, 2.1rem);
    font-weight: 780;
    margin-bottom: 16px;
  }

  .flash-back-root {
    font-size: clamp(2rem, 7vw, 3.6rem);
    line-height: 1;
  }

  .flash-description {
    color: var(--wr-ink-muted);
    margin: 18px auto 0;
    max-width: 620px;
  }

  .flash-examples {
    display: grid;
    gap: 8px;
    margin-top: 18px;
    width: min(100%, 520px);
  }

  .flash-example {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    border: 1px solid var(--wr-rule);
    border-radius: var(--wr-radius);
    background: color-mix(
      in srgb,
      var(--wr-paper-deep) 50%,
      var(--wr-paper-panel)
    );
    padding: 9px 11px;
    text-align: left;
  }

  .flash-example span {
    color: var(--wr-ink-muted);
  }

  .flash-inline-actions,
  .flash-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .flash-inline-actions {
    margin-top: 20px;
  }

  .flash-progress {
    color: var(--wr-ink-muted);
    font-weight: 760;
    min-width: 170px;
    text-align: center;
  }

  .flash-hint {
    color: var(--wr-ink-faint);
    margin: 0;
    text-align: center;
  }

  @media (max-width: 700px) {
    .flash-card {
      min-height: 500px;
    }
  }
</style>
