---
import type { WordRoot } from '@/data/wordRoots'
import { displayOrigin } from '@/lib/origin'

const { root } = Astro.props as { root: WordRoot }
---

<a
  class="root-card"
  href={`/roots/${root.id}`}
  data-root-card
  data-origin={root.origin}
  data-search={`${root.root} ${root.meaning} ${displayOrigin(root.origin)} ${root.description} ${root.examples.map((item) => `${item.word} ${item.meaning}`).join(' ')}`.toLowerCase()}
>
  <div class="root-card__top">
    <span class="root-card__root wr-wordmark">{root.root}</span>
    <span class="wr-chip">{displayOrigin(root.origin)}</span>
  </div>
  <p>{root.meaning}</p>
  <div class="wr-chip-row" aria-label={`${root.root} 例词`}>
    {
      root.examples
        .slice(0, 3)
        .map((example) => <span class="wr-chip">{example.word}</span>)
    }
  </div>
  <span class="root-card__id">#{root.id}</span>
</a>

<style>
  .root-card {
    position: relative;
    display: block;
    min-height: 174px;
    border: 1px solid var(--wr-rule);
    border-radius: var(--wr-radius);
    background: var(--wr-paper-panel);
    padding: 18px;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .root-card:hover {
    border-color: var(--wr-rule-strong);
    box-shadow: inset 0 -3px 0
      color-mix(in srgb, var(--wr-ochre) 13%, transparent);
    text-decoration: none;
  }

  .root-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .root-card__root {
    font-size: 1.16rem;
  }

  .root-card p {
    color: var(--wr-ink-muted);
    margin: 10px 0 16px;
  }

  .root-card__id {
    position: absolute;
    right: 16px;
    bottom: 12px;
    color: var(--wr-ink-faint);
    font-size: 0.78rem;
  }
</style>
