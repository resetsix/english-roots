---
import '../styles/global.css'
import 'lxgw-wenkai-screen-webfont/lxgwwenkaiscreen.css'

type NavItem = {
  href: string
  label: string
}

type Props = {
  title?: string
  description?: string
  activePath?: string
}

const {
  title = '词词有据',
  description = '用词根公式记英语单词。',
  activePath = '/',
} = Astro.props as Props

const navItems: NavItem[] = [
  { href: '/learn', label: '学习' },
  { href: '/flashcard', label: '闪卡' },
  { href: '/roots', label: '列表' },
  { href: '/progress', label: '进度' },
]

const currentYear = new Date().getFullYear()
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <script is:inline>
      try {
        const settings = JSON.parse(
          localStorage.getItem('wordRootSettings') || '{}',
        )
        if (settings.readingTheme === 'classic') {
          document.documentElement.dataset.readingTheme = 'classic'
        } else {
          delete document.documentElement.dataset.readingTheme
        }
        document.documentElement.dataset.wordAudioEnabled = String(
          settings.audioEnabled === true,
        )
      } catch {
        delete document.documentElement.dataset.readingTheme
        document.documentElement.dataset.wordAudioEnabled = 'false'
      }
    </script>

    <title>{title}</title>
  </head>
  <body>
    <div class="word-root-app">
      <nav class="wr-nav" aria-label="主导航">
        <div class="wr-container wr-nav__inner">
          <a class="wr-brand" href="/">
            <span class="wr-brand-mark" aria-hidden="true">词</span>
            <span>词词有据</span>
          </a>

          <div class="wr-nav__right">
            <div class="wr-nav__links">
              {
                navItems.map((item) => (
                  <a
                    class="wr-nav__link"
                    href={item.href}
                    aria-current={activePath === item.href ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                ))
              }
            </div>
            <div class="wr-audio-controls" aria-label="单词发音设置">
              <button
                class="wr-audio-toggle"
                type="button"
                data-word-audio-enabled-toggle
                aria-label="开启单词发音"
                aria-pressed="false"
                title="开启单词发音"
              >
                发音
              </button>
              <div class="wr-accent-toggle" role="group" aria-label="发音口音">
                <button
                  type="button"
                  data-word-audio-accent="us"
                  aria-label="使用美式发音"
                  title="使用美式发音"
                >
                  美式
                </button>
                <button
                  type="button"
                  data-word-audio-accent="uk"
                  aria-label="使用英式发音"
                  title="使用英式发音"
                >
                  英式
                </button>
              </div>
            </div>
          </div>
        </div>
      </nav>

      <main class="wr-main">
        <slot />
      </main>

      <footer class="wr-footer">
        <div class="wr-footer__inner">
          <span>词词有据 · 单词 = 前缀 + 词根 + 后缀</span>
          <span class="wr-footer__related">
            <span>音标有谱 ·</span>
            <a
              class="wr-footer__link"
              href="https://english-ipa.netlify.app"
              target="_blank"
              rel="noreferrer"
            >
              english-ipa.netlify.app
            </a>
          </span>
          <span>©{currentYear} 未有期. All rights reserved.</span>
        </div>
      </footer>
    </div>
  </body>
</html>

<script>
  import { initAudioAccentToggle, initWordAudioControls } from '@/lib/wordAudio'

  initAudioAccentToggle()
  initWordAudioControls()
</script>
