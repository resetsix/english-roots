---
import '../styles/global.css'

type NavItem = {
  href: string
  label: string
}

type Props = {
  title?: string
  description?: string
  activePath?: string
}

const {
  title = '词词有据',
  description = '用词根公式记英语单词。',
  activePath = '/',
} = Astro.props as Props

const navItems: NavItem[] = [
  { href: '/learn', label: '学习' },
  { href: '/flashcard', label: '闪卡' },
  { href: '/roots', label: '列表' },
  { href: '/progress', label: '进度' },
]

const currentYear = new Date().getFullYear()
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <script is:inline>
      try {
        const settings = JSON.parse(
          localStorage.getItem('wordRootSettings') || '{}',
        )
        if (settings.readingTheme === 'classic') {
          document.documentElement.dataset.readingTheme = 'classic'
        } else {
          delete document.documentElement.dataset.readingTheme
        }
      } catch {
        delete document.documentElement.dataset.readingTheme
      }
    </script>
    <script is:inline>
      ;(() => {
        const root = document.documentElement
        const family = 'LXGW WenKai Screen'
        const timeoutMs = 1800
        let settled = false

        root.classList.add('fonts-loading')

        const finish = (className) => {
          if (settled) return
          settled = true
          root.classList.remove('fonts-loading')
          root.classList.add(className)
        }

        if (!('fonts' in document)) {
          finish('fonts-timeout')
          return
        }

        window.setTimeout(() => finish('fonts-timeout'), timeoutMs)

        const loadFont = () => {
          document.fonts
            .load(`1em "${family}"`)
            .then(() => document.fonts.ready)
            .then(() => finish('fonts-ready'))
            .catch(() => finish('fonts-timeout'))
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', loadFont, {
            once: true,
          })
        } else {
          loadFont()
        }
      })()
    </script>
    <link
      rel="preload"
      href="/fonts/LXGWWenKaiScreen-subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="word-root-app">
      <nav class="wr-nav" aria-label="主导航">
        <div class="wr-container wr-nav__inner">
          <a class="wr-brand" href="/">
            <span class="wr-brand-mark" aria-hidden="true">词</span>
            <span>词词有据</span>
          </a>

          <div class="wr-nav__links">
            {
              navItems.map((item) => (
                <a
                  class="wr-nav__link"
                  href={item.href}
                  aria-current={activePath === item.href ? 'page' : undefined}
                >
                  {item.label}
                </a>
              ))
            }
          </div>
        </div>
      </nav>

      <main class="wr-main">
        <slot />
      </main>

      <footer class="wr-footer">
        <div class="wr-footer__inner">
          <span>词词有据 · 单词 = 前缀 + 词根 + 后缀</span>
          <span class="wr-footer__related">
            <span>音标有谱 ·</span>
            <a
              class="wr-footer__link"
              href="https://english-ipa.netlify.app"
              target="_blank"
              rel="noreferrer"
            >
              english-ipa.netlify.app
            </a>
          </span>
          <span>©{currentYear} 未有期. All rights reserved.</span>
        </div>
      </footer>
    </div>
  </body>
</html>
